{
  "name": "dashboard",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/dashboard/src",
  "projectType": "application",
  "tags": ["scope:dashboard", "type:app"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": [],
      "options": {
        "command": "pnpm build",
        "cwd": "packages/dashboard"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm dev",
        "cwd": "packages/dashboard"
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{workspaceRoot}/coverage/packages/dashboard"],
      "dependsOn": [{ "target": "build", "projects": ["cli"] }],
      "options": {
        "config": "packages/dashboard/vitest.config.ts"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p tsconfig.typecheck.json",
        "cwd": "{projectRoot}"
      }
    }
  }
}

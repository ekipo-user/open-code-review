{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node", "vitest/globals", "vitest/importMeta"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "../cli/src/lib/db/**/*.ts",
    "../shared/platform/src/**/*.ts",
    "vitest.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "../cli/**/*.test.ts",
    "../shared/**/*.test.ts"
  ]
}
